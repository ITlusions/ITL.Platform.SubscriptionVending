# Copy this file to .env and fill in the values.
# All variables use the VENDING_ prefix.

# ── Azure credentials ─────────────────────────────────────────────────────────
# Leave VENDING_AZURE_CLIENT_ID and VENDING_AZURE_CLIENT_SECRET empty to use
# Managed Identity (recommended in Azure-hosted environments).
VENDING_AZURE_TENANT_ID=<your-tenant-id>
VENDING_AZURE_CLIENT_ID=
VENDING_AZURE_CLIENT_SECRET=

# Root management group name (default: ITL)
VENDING_ROOT_MANAGEMENT_GROUP=ITL

# ── Tag-based management group mapping ───────────────────────────────────────
# JSON object mapping environment names to management group names.
# Supports unlimited custom environments — add any key/value pair you need.
# Override VENDING_ENVIRONMENT_MG_MAPPING with a JSON string to customise.
#
# Example with extra environments:
# VENDING_ENVIRONMENT_MG_MAPPING='{"production":"ITL-Production","staging":"ITL-Staging","development":"ITL-Development","sandbox":"ITL-Sandbox","acceptance":"ITL-Acceptance","test":"ITL-Test"}'
VENDING_ENVIRONMENT_MG_MAPPING='{
  "production": "ITL-Production",
  "staging": "ITL-Staging",
  "development": "ITL-Development",
  "sandbox": "ITL-Sandbox"
}'

# Default e-mail for budget alerts when the itl-owner tag is absent.
VENDING_DEFAULT_ALERT_EMAIL=

# ── Authorization service ─────────────────────────────────────────────────────
VENDING_AUTHORIZATION_SERVICE_URL=http://itl-authorization:8004

# ── Keycloak ─────────────────────────────────────────────────────────────────
VENDING_KEYCLOAK_URL=http://keycloak:8080
VENDING_KEYCLOAK_REALM=ITL

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to enable POST /webhook/test mock endpoint.
VENDING_MOCK_MODE=false

# ── RBAC — object IDs for initial role assignments on new subscriptions ───────
VENDING_PLATFORM_SPN_OBJECT_ID=
VENDING_OPS_GROUP_OBJECT_ID=
VENDING_SECURITY_GROUP_OBJECT_ID=
VENDING_FINOPS_GROUP_OBJECT_ID=

# ── Event Grid ───────────────────────────────────────────────────────────────
# SAS key used to validate incoming Event Grid deliveries.
VENDING_EVENT_GRID_SAS_KEY=
