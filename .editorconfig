root = true

# ── All files ──────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# ── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 100

# ── YAML / YAML-adjacent ──────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── JSON / JSONC ──────────────────────────────────────────────────────────────
[*.{json,jsonc}]
indent_size = 2

# ── TOML ──────────────────────────────────────────────────────────────────────
[*.toml]
indent_size = 4

# ── Bicep / ARM ───────────────────────────────────────────────────────────────
[*.{bicep,bicepparam,json}]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false

# ── Dockerfile ────────────────────────────────────────────────────────────────
[Dockerfile*]
indent_size = 2

# ── Shell / PowerShell ────────────────────────────────────────────────────────
[*.{sh,bash,ps1,psm1,psd1}]
indent_size = 4
end_of_line = lf

# ── Kubernetes manifests ──────────────────────────────────────────────────────
[k8s/**]
indent_size = 2

# ── Makefiles require tabs ────────────────────────────────────────────────────
[Makefile]
indent_style = tab
